# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
RELOAD=True

# Data Directory
# TIF_DIR=data/tif_files

# CORS Settings
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:19006"]

# PM2.5 Settings
DEFAULT_COLORMAP=aqi
DEFAULT_OPACITY=0.6

# Firebase Configuration
# Get your Firebase API Key from: Firebase Console -> Project Settings -> General -> Web API Key
FIREBASE_API_KEY=your_firebase_web_api_key_here

# Optional: Firebase Admin SDK (for better user management)
# Download service account JSON from: Firebase Console -> Project Settings -> Service Accounts
# FIREBASE_SERVICE_ACCOUNT=C:\path\to\serviceAccountKey.json

# MinIO Configuration for TIF Downloader
MINIO_ENDPOINT=112.137.129.244:9001
MINIO_ACCESS_KEY=your_access_key_here
MINIO_SECRET_KEY=your_secret_key_here
MINIO_BUCKET=nrt-sci-pm25-map-daily-1km
MINIO_SECURE=false

# AI Chat (RAG + Text-to-SQL)
# LLM_PROVIDER chọn "gemini" hoặc "groq" — đổi sang groq khi Gemini free-tier hết quota
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your_google_api_key_here
LLM_MODEL=gemini-2.5-flash
# Lấy GROQ_API_KEY (free) tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL_GROQ=llama-3.3-70b-versatile